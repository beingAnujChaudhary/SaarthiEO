# ==========================================================
# SaarthiEO - Production .gitignore
# AI | Computer Vision | Remote Sensing | Streamlit
# ==========================================================

# ==========================================================
# Python
# ==========================================================

__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ==========================================================
# Virtual Environments
# ==========================================================

.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

.python-version

# ==========================================================
# Environment Variables
# ==========================================================

.env
.env.*
!.env.example

# ==========================================================
# Jupyter
# ==========================================================

.ipynb_checkpoints/

# ==========================================================
# VS Code / PyCharm
# ==========================================================

.vscode/
.idea/

# ==========================================================
# Operating System Files
# ==========================================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Logs
# ==========================================================

*.log
logs/

# ==========================================================
# Testing
# ==========================================================

.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ==========================================================
# Ruff / MyPy
# ==========================================================

.ruff_cache/
.mypy_cache/
.pyre/
.pytype/

# ==========================================================
# Build Files
# ==========================================================

build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ==========================================================
# Streamlit
# ==========================================================

.streamlit/
.streamlit/secrets.toml

# ==========================================================
# Data
# ==========================================================

data/raw/*
data/processed/*
data/gallery/*
data/interim/*
data/external/*

!data/raw/.gitkeep
!data/processed/.gitkeep
!data/gallery/.gitkeep
!data/interim/.gitkeep
!data/external/.gitkeep

# ==========================================================
# Artifacts
# ==========================================================

artifacts/*
!artifacts/.gitkeep

artifacts/cache/*
artifacts/checkpoints/*
artifacts/embeddings/*
artifacts/faiss/*
artifacts/metrics/*
artifacts/results/*

!artifacts/cache/.gitkeep
!artifacts/checkpoints/.gitkeep
!artifacts/embeddings/.gitkeep
!artifacts/faiss/.gitkeep
!artifacts/metrics/.gitkeep
!artifacts/results/.gitkeep

# ==========================================================
# Models
# ==========================================================

models/*
!models/.gitkeep

checkpoints/*
!checkpoints/.gitkeep

# ==========================================================
# Dataset Files
# ==========================================================

*.zip
*.tar
*.tar.gz
*.gz
*.7z
*.rar

# ==========================================================
# Geospatial Data
# ==========================================================

*.tif
*.tiff
*.jp2
*.img

# ==========================================================
# HDF5
# ==========================================================

*.h5
*.hdf5

# ==========================================================
# NumPy
# ==========================================================

*.npy
*.npz

# ==========================================================
# Deep Learning Models
# ==========================================================

*.pt
*.pth
*.ckpt
*.bin
*.onnx
*.pb
*.weights
*.engine
*.safetensors

# ==========================================================
# FAISS
# ==========================================================

*.index

# ==========================================================
# Experiment Outputs
# ==========================================================

outputs/
results/
cache/
runs/
wandb/
mlruns/

# ==========================================================
# TensorBoard
# ==========================================================

events.out.tfevents.*

# ==========================================================
# Temporary Files
# ==========================================================

tmp/
temp/
*.tmp

# ==========================================================
# PDF Reports (Generated)
# ==========================================================

reports/generated/*
!reports/generated/.gitkeep

# ==========================================================
# Ignore Google Drive Sync Files
# ==========================================================

*.gdoc
*.gsheet
*.gslides

# ==========================================================
# Ignore Downloaded BigEarthNet / SEN12MS Files
# ==========================================================

bigearthnet*.gz
bigearthnet*.hdf5

sen12ms*
SEN12MS*

# ==========================================================
# Local Tunnel
# ==========================================================

.lt/

# ==========================================================
# Mac/Linux
# ==========================================================

.AppleDouble
.LSOverride

# ==========================================================
# Windows
# ==========================================================

ehthumbs.db

# ==========================================================
# Keep Folder Structure
# ==========================================================

!.gitkeep

# ==========================================================
# END
# ==========================================================