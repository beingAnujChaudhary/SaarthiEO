# ==========================================================
# SaarthiEO — .gitignore
# ==========================================================

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ─────────────────────────────────
venv/
.venv/
env/
ENV/
.env

# ── Jupyter / IPython ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Model checkpoints (large binary files) ──────────────
# Track ONLY best_efficientnet_b3.pth via Git LFS
# Ignore the rest (intermediate checkpoints, duplicates)
models/efficientnet_b3_checkpoint.pth
models/efficientnet_b3_complete.pth
models/efficientnet_b3_weights.pth
models/efficientnet_b3_torchscript.pt
models/*.onnx
models/*.onnx.data

# ── Training / experiment artefacts ─────────────────────
runs/
wandb/
mlruns/
lightning_logs/
*.log
*.out

# ── OS files ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs & editors ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── Gradio temp files ────────────────────────────────────
.gradio/
gradio_cached_examples/

# ── Data directories (datasets not committed to git) ─────
data/
datasets/
raw_data/

# ── Temporary / build artefacts ──────────────────────────
*.egg-info/
dist/
build/
.eggs/
*.egg
MANIFEST

# ── Environment variables / secrets ──────────────────────
.env
.env.local
.env.*.local
secrets.json
*.key

# ── Coverage / testing ───────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
*.cover

# ── Type checking ────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
